# Example local config (env format). Copy and edit locally.
YGG_UI_MODE="simple"
YGG_SETUP_MODE="recommended"
YGG_BUILD_PROFILE="both"
YGG_ENABLE_QEMU_SMOKE="false"
YGG_INFISICAL_BOOT_MODE="disabled"
YGG_INFISICAL_CONTAINER_NAME="infisical"
YGG_EMBED_SSH_KEYS="true"
YGG_SSH_AUTHORIZED_KEYS_FILE="/root/.ssh/authorized_keys"
YGG_HOSTNAME=""
YGG_NET_MODE="dhcp"
YGG_LXC_PARENT_IF="eno1"
YGG_MACVLAN_CIDR="10.10.0.250/24"
YGG_MACVLAN_ROUTE="10.10.0.0/24"
YGG_STATIC_IFACE="eno1"
YGG_STATIC_IP=""
YGG_STATIC_GATEWAY=""
YGG_STATIC_DNS=""
YGG_APT_HTTP_PROXY=""
YGG_APT_HTTPS_PROXY=""
YGG_APT_PROXY_BYPASS_HOST=""
YGG_ENABLE_INTEL_ARC_SRIOV="false"
YGG_INTEL_ARC_SRIOV_RELEASE="2026.03.05"
YGG_INTEL_ARC_SRIOV_VF_COUNT="7"
YGG_INTEL_ARC_SRIOV_PF_PCI=""
YGG_INTEL_ARC_SRIOV_DEVICE_ID="0x56a0"
YGG_INTEL_ARC_SRIOV_BIND_VFS="vfio-pci"
